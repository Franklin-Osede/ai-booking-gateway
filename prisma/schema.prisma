generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Clinic {
  id        String   @id @default(uuid())
  slug      String?  @unique
  name      String
  industry  String
  location  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  websites       Website[]
  brandings      Branding[]
  widgetConfigs  WidgetConfig[]
  outreachLogs   OutreachLog[]
  events         ClinicEvent[]

  @@index([name])
  @@index([slug])
  @@index([industry])
}

model Website {
  id              String    @id @default(uuid())
  clinicId        String
  url             String
  screenshotUrl   String?
  lastScrapedAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  clinic          Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
}

model Branding {
  id              String   @id @default(uuid())
  clinicId        String
  primaryColor    String
  secondaryColor  String?
  buttonStyle     String?
  logoUrl         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clinic          Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
}

model WidgetConfig {
  id                String   @id @default(uuid())
  clinicId          String
  demoLink          String?
  selectedProducts  Json?
  formType          String?
  voiceAgent        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  clinic            Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
}

model OutreachLog {
  id                String   @id @default(uuid())
  clinicId          String
  status            String
  channel           String?
  nextStep          String?
  owner             String?
  lastContactedAt   DateTime?
  createdAt         DateTime @default(now())

  clinic            Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
}

model PronunciationProfile {
  id         String   @id @default(uuid())
  scopeType  String   // "niche" or "clinic"
  scopeId    String   // e.g. "hair_transplant" or "clinic_123"
  locale     String   @default("es-ES")
  version    Int      @default(1)
  rules      Json     @default("[]")
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@unique([scopeType, scopeId, locale])
  @@index([scopeId, locale])
}

model ClinicEvent {
  id           String    @id @default(uuid())
  clinicId     String
  eventDate    DateTime
  reminderDate DateTime?
  feedback     String?
  nextAction   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  clinic       Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([eventDate])
}
